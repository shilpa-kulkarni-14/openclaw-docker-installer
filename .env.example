# ============================================================================
# OpenClaw Docker — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# Your .env file is git-ignored and never committed.
# ============================================================================

# Required: Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional: OpenAI API key (for GPT-4 dual-model support)
# OPENAI_API_KEY=

# Optional: Channels to enable (comma-separated)
# Examples: slack, discord, telegram, whatsapp, msteams, webchat
# OPENCLAW_CHANNELS=slack
