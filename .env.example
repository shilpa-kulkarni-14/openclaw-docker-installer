# ============================================================================
# OpenClaw Docker — Environment Variables
# ============================================================================
# Copy this file to .env and fill in at least one API key:
#   cp .env.example .env
#
# Your .env file is git-ignored and never committed.
# ============================================================================

# At least one AI provider key is required. Pick any — add as many as you like.

# Anthropic (Claude) — console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI (GPT-4) — platform.openai.com
# OPENAI_API_KEY=

# Google Gemini — aistudio.google.com
# GOOGLE_API_KEY=

# Mistral — console.mistral.ai
# MISTRAL_API_KEY=

# Groq (fast Llama/Mixtral) — console.groq.com
# GROQ_API_KEY=

# DeepSeek — platform.deepseek.com
# DEEPSEEK_API_KEY=

# OpenRouter (100+ models) — openrouter.ai
# OPENROUTER_API_KEY=

# Cohere — dashboard.cohere.com
# COHERE_API_KEY=

# Optional: Override auto-detected primary model
# If omitted, the installer picks the model matching the first provider key found.
# Only needed if you want a specific model when multiple keys are set.
# OPENCLAW_PRIMARY_MODEL=google/gemini-2.0-flash

# Optional: Channels to enable (comma-separated)
# Examples: slack, discord, telegram, whatsapp, msteams, webchat
# OPENCLAW_CHANNELS=slack
